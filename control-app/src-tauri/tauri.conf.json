{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zephyros Control App",
  "version": "1.0.0",
  "identifier": "com.mech2a2.zephyros",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zephyros Control App",
        "width": 1300,
        "height": 950
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": { "infoPlist": "Info.plist" }
  }
}